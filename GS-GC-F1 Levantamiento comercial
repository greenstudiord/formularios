<script>
// ╔══════════════════════════════════════════════════════════════════════╗
// ║  CONFIGURACIÓN — INTEGRACIÓN SHAREPOINT / AZURE / POWER AUTOMATE   ║
// ╠══════════════════════════════════════════════════════════════════════╣
// ║  PASO 1 — Azure Portal (portal.azure.com)                           ║
// ║    · Entra ID → App registrations → New registration                ║
// ║    · Redirect URI: Single-page application → URL del formulario     ║
// ║    · API permissions: User.Read, Sites.ReadWrite.All                ║
// ║    · Copia el Application (client) ID y el Directory (tenant) ID    ║
// ║                                                                      ║
// ║  PASO 2 — Power Automate (make.powerautomate.com)                   ║
// ║    · Nuevo flujo: "When an HTTP request is received"                ║
// ║    · Acción 1: SharePoint → "Create item" → lista Levantamientos    ║
// ║    · Acción 2: Teams → "Post message in a channel"                  ║
// ║                  Canal: "A cotizar" (Administración)                ║
// ║                                                                      ║
// ║  Mensaje sugerido para Teams canal "A cotizar":                     ║
// ║  📋 Nuevo levantamiento comercial                                   ║
// ║  Cliente: @{triggerBody()?['cliente_nombre']}                       ║
// ║  Encargado: @{triggerBody()?['encargado']}                          ║
// ║  Líneas: @{triggerBody()?['lineas_servicio']}                       ║
// ║  Presupuesto: @{triggerBody()?['presupuesto']}                      ║
// ║  Estado: @{triggerBody()?['estado_prospecto']}                      ║
// ║  Próxima acción: @{triggerBody()?['proxima_accion']}                ║
// ║                                                                      ║
// ║  PASO 3 — SharePoint List (Columnas recomendadas)                   ║
// ║    Title (texto), encargado, encargado_email, fecha_levantamiento,  ║
// ║    cliente_nombre, cliente_rnc, cliente_telefono, cliente_whatsapp,  ║
// ║    cliente_email, como_conocio, tipo_cliente, direccion, sector,     ║
// ║    nombre_proyecto, lineas_servicio, alcance, area_m2, tipo_espacio, ║
// ║    estilo_diseno, uso_espacio, presupuesto, urgencia, condicion_pago,║
// ║    temperatura, estado_prospecto, proxima_accion, fecha_seguimiento, ║
// ║    fecha_registro (todos Texto de una línea o Fecha según tipo)      ║
// ║                                                                      ║
// ║  PASO 4 — Activar aquí                                              ║
// ║    · Cambia AUTH_ACTIVO a true                                       ║
// ║    · Pega CLIENT_ID, TENANT_ID y PA_URL                             ║
// ╚══════════════════════════════════════════════════════════════════════╝
const CFG = {
  AUTH_ACTIVO:  false,                        // ← true cuando tengas Entra ID
  CLIENT_ID:    "TU-CLIENT-ID",               // ← portal.azure.com → Entra ID → App registrations
  TENANT_ID:    "TU-TENANT-ID",               // ← portal.azure.com → Entra ID → Overview
  PA_URL:       "TU-URL-POWER-AUTOMATE",      // ← make.powerautomate.com → HTTP trigger URL
  DOMINIO:      "greenstudiord.com",          // ← dominio corporativo para validar correo
};
// ═══════════════════════════════════════════════════════════════════════

let msalInst = null, userAcc = null, datos = {};
let cur = 0; const TOTAL = 5;

async function boot() {
  const hoy = new Date().toISOString().split('T')[0];
  document.getElementById('fecha-lev').value = hoy;
  document.querySelectorAll('input[type=date]').forEach(d=>{ if(!d.value) d.value=hoy; });

  if (CFG.AUTH_ACTIVO) {
    document.getElementById('demo-badge').classList.add('hidden');
    document.getElementById('login-note').textContent = `Solo accesible con cuenta @${CFG.DOMINIO}.`;
    try {
      msalInst = new msal.PublicClientApplication({
        auth:{ clientId:CFG.CLIENT_ID, authority:`https://login.microsoftonline.com/${CFG.TENANT_ID}`, redirectUri: location.href.split('?')[0] }
      });
      await msalInst.initialize();
      const r = await msalInst.handleRedirectPromise();
      if(r){ procesarLogin(r); return; }
      const cuentas = msalInst.getAllAccounts();
      if(cuentas.length){ procesarLogin({account:cuentas[0]}); return; }
    } catch(e){ console.warn(e); }
    document.getElementById('login-overlay').classList.add('vis');
  } else {
    // Modo local: acceso directo sin autenticación
    document.getElementById('formulario-main').style.display='block';
    actualizarNotaCierre();
    updateNav();
  }
}

async function iniciarLogin() {
  const btn=document.getElementById('btn-login');
  btn.disabled=true; btn.innerHTML='<span class="spinner"></span> Conectando...';
  document.getElementById('login-error').style.display='none';
  try {
    const r = await msalInst.loginPopup({scopes:['User.Read']});
    procesarLogin(r);
  } catch(e) {
    btn.disabled=false;
    btn.innerHTML='<svg viewBox="0 0 21 21" fill="none"><rect x="1" y="1" width="9" height="9" fill="#F25022"/><rect x="11" y="1" width="9" height="9" fill="#7FBA00"/><rect x="1" y="11" width="9" height="9" fill="#00A4EF"/><rect x="11" y="11" width="9" height="9" fill="#FFB900"/></svg> Iniciar sesión con Microsoft';
    const el=document.getElementById('login-error');
    el.style.display='block';
    el.textContent=e.errorCode==='user_cancelled'?'Inicio de sesión cancelado.':'Error al conectar. Intenta de nuevo.';
  }
}

function procesarLogin(r) {
  const email=r.account.username, dom=email.split('@')[1];
  // Verificación de correo corporativo — solo permite @DOMINIO
  if(dom!==CFG.DOMINIO){
    const el=document.getElementById('login-error');
    el.style.display='block'; el.textContent=`Acceso restringido. Solo cuentas @${CFG.DOMINIO}.`;
    document.getElementById('btn-login').disabled=false;
    msalInst.logoutPopup({account:r.account}).catch(()=>{});
    return;
  }
  userAcc=r.account;
  const nombre=r.account.name||email;
  const ini=nombre.split(' ').map(n=>n[0]).join('').toUpperCase().slice(0,2);
  document.getElementById('u-avatar').textContent=ini;
  document.getElementById('u-name').textContent=nombre;
  document.getElementById('u-email').textContent=email;
  document.getElementById('user-bar').classList.add('vis');
  document.getElementById('demo-badge').classList.add('hidden');
  const enc=document.getElementById('encargado');
  enc.value=nombre; enc.readOnly=true;
  document.getElementById('login-overlay').classList.remove('vis');
  document.getElementById('formulario-main').style.display='block';
  actualizarNotaCierre();
  updateNav();
}

function actualizarNotaCierre() {
  const paListo = CFG.PA_URL && CFG.PA_URL.startsWith('https');
  if(!paListo){
    const n=document.getElementById('nota-cierre');
    n.style.borderLeftColor='var(--border)'; n.style.background='var(--leaf-mist)'; n.style.color='var(--ink-soft)';
    n.textContent='Modo local — los datos se guardarán y podrás descargar Word y PDF. La integración con SharePoint y el canal A cotizar en Teams se activa cuando configures AUTH_ACTIVO, CLIENT_ID, TENANT_ID y PA_URL en el bloque CFG.';
  }
}

function goTo(n){
  document.querySelectorAll('.section')[cur].classList.remove('visible');
  document.querySelectorAll('.step')[cur].classList.remove('active');
  if(cur<n) document.querySelectorAll('.step')[cur].classList.add('done');
  cur=n;
  document.querySelectorAll('.section')[cur].classList.add('visible');
  document.querySelectorAll('.step')[cur].classList.add('active');
  updateNav(); window.scrollTo({top:0,behavior:'smooth'});
}
async function navNext(){ if(cur<TOTAL-1) goTo(cur+1); else await enviar(); }
function navBack(){ if(cur>0) goTo(cur-1); }
function updateNav(){
  document.getElementById('btn-back').style.visibility=cur===0?'hidden':'visible';
  document.getElementById('btn-next').textContent=cur===TOTAL-1?'Guardar y enviar ✓':'Siguiente →';
  document.getElementById('step-ctr').textContent=`Paso ${cur+1} de ${TOTAL}`;
}

function selChip(el,g){ document.getElementById(g).querySelectorAll('.chip').forEach(c=>c.classList.remove('sel')); el.classList.add('sel'); }
function selChipMulti(el){ el.classList.toggle('sel'); }
function toggleCC(cb){ cb.closest('.cc').classList.toggle('sel-card',cb.checked); }
function selBudget(el){ document.getElementById('budget').querySelectorAll('.budget-opt').forEach(o=>o.classList.remove('sel')); el.classList.add('sel'); }
function selUrg(el){ document.getElementById('urgencia').querySelectorAll('.urg-opt').forEach(o=>o.classList.remove('sel')); el.classList.add('sel'); }

function chips(id){ return [...document.getElementById(id).querySelectorAll('.chip.sel')].map(c=>c.textContent).join(', '); }
function checks(id){ return [...document.getElementById(id).querySelectorAll('input[type=checkbox]:checked')].map(c=>c.closest('.cc').querySelector('.cc-text').textContent).join(', '); }
function v(id){ return document.getElementById(id)?document.getElementById(id).value:''; }

function recolectar(){
  const bud=document.querySelector('#budget .budget-opt.sel');
  const urg=document.querySelector('#urgencia .urg-opt.sel');
  return {
    // "Title" es requerido por SharePoint List — usa nombre del cliente
    Title: v('cli-nombre') || 'Sin nombre',
    encargado: v('encargado'),
    encargado_email: userAcc ? userAcc.username : '',
    fecha_levantamiento: v('fecha-lev'),
    cliente_nombre: v('cli-nombre'),
    cliente_rnc: v('cli-rnc'),
    cliente_telefono: v('cli-tel'),
    cliente_whatsapp: v('cli-wa'),
    cliente_email: v('cli-email'),
    como_conocio: chips('origen'),
    referido: v('referido'),
    tipo_cliente: v('tipo-cliente'),
    direccion: v('direccion'),
    sector: v('sector'),
    nombre_proyecto: v('nom-proyecto'),
    lineas_servicio: checks('lineas-serv'),
    alcance: chips('alcance'),
    area_m2: v('area'),
    tipo_espacio: v('tipo-espacio'),
    estilo_diseno: chips('estilo'),
    uso_espacio: chips('uso'),
    referencias_positivas: v('ref-pos'),
    referencias_negativas: v('ref-neg'),
    componentes_diseno: checks('comp-diseno'),
    vegetacion_existente: chips('existente'),
    observaciones: v('obs'),
    presupuesto: bud ? bud.querySelector('.amt').textContent : '',
    urgencia: urg ? urg.textContent : '',
    condicion_pago: v('cond-pago'),
    competencia: v('competencia'),
    fecha_visita: v('fecha-visita'),
    temperatura: v('temperatura'),
    notas_ventas: v('notas-ventas'),
    estado_prospecto: v('estado'),
    proxima_accion: v('prox-accion'),
    fecha_seguimiento: v('fecha-seg'),
    notif_diseno: v('notif'),
    confirmacion_cliente: v('conf-cliente'),
    fecha_registro: new Date().toISOString(),
  };
}

async function enviar(){
  const btn=document.getElementById('btn-next');
  btn.disabled=true; btn.innerHTML='<span class="spinner"></span> Guardando...';
  datos=recolectar();
  const paListo=CFG.PA_URL&&CFG.PA_URL.startsWith('https');
  if(paListo){
    try{
      // Obtener token de acceso si hay sesión activa (para autenticar ante Power Automate)
      let tok='';
      if(userAcc&&msalInst){
        try{
          const tr=await msalInst.acquireTokenSilent({scopes:['User.Read'],account:userAcc});
          tok=tr.accessToken;
        }catch(e){}
      }
      // Enviar a Power Automate → SharePoint List
      const r=await fetch(CFG.PA_URL,{
        method:'POST',
        headers:{
          'Content-Type':'application/json',
          ...(tok?{'Authorization':'Bearer '+tok}:{})
        },
        body:JSON.stringify(datos)
      });
      if(!r.ok) throw new Error('HTTP '+r.status);
      mostrarExito(true);
    }catch(e){
      btn.disabled=false; btn.textContent='Guardar y enviar ✓';
      alert('Error al guardar en SharePoint.\n\nVerifica:\n· PA_URL está correctamente pegado\n· El flujo de Power Automate está activo\n· Los permisos del tenant permiten llamadas externas\n\nDetalle: '+e.message);
    }
  } else {
    mostrarExito(false);
  }
}

function mostrarExito(conectado){
  document.querySelectorAll('.section').forEach(s=>s.style.display='none');
  document.getElementById('nav-bar').style.display='none';
  document.getElementById('success').style.display='block';
  document.querySelectorAll('.step')[cur].classList.remove('active');
  document.querySelectorAll('.step')[cur].classList.add('done');
  if(conectado){
    document.getElementById('suc-msg').textContent='Registrado en SharePoint. Notificación enviada al canal A cotizar en Teams.';
    document.getElementById('suc-steps').innerHTML='<div class="ns-item"><strong>SharePoint</strong>Item creado en la lista</div><div class="ns-item"><strong>Teams — A cotizar</strong>Notificación enviada</div><div class="ns-item"><strong>Word / PDF</strong>Listos para descargar</div>';
  } else {
    document.getElementById('suc-msg').textContent='Datos guardados localmente. Descarga Word o PDF para conservar el registro. La sincronización con SharePoint se activa al configurar la conexión.';
    document.getElementById('suc-steps').innerHTML='<div class="ns-item"><strong>Local</strong>Datos guardados</div><div class="ns-item"><strong>Word / PDF</strong>Listos para descargar</div>';
  }
  setTimeout(()=>descargarWord(),800);
}

async function descargarWord(){
  const d=datos;
  if(!d||!Object.keys(d).length){alert('Completa y guarda el formulario primero.');return;}
  const{Document,Paragraph,TextRun,Table,TableRow,TableCell,WidthType,BorderStyle,AlignmentType,Packer,ShadingType}=docx;
  const V='4a7c59',GCL='f2f7f3',INK='1c2b1f',SO='6b8870',GRD='c9d9cc';
  const nb={style:BorderStyle.NONE}, sb={style:BorderStyle.SINGLE,size:2,color:GRD};
  const fila=(l,val)=>new TableRow({children:[
    new TableCell({width:{size:32,type:WidthType.PERCENTAGE},shading:{fill:GCL,type:ShadingType.CLEAR},borders:{top:nb,bottom:sb,left:nb,right:nb},children:[new Paragraph({spacing:{before:60,after:60},children:[new TextRun({text:l,size:18,color:SO,font:'Calibri'})]})]}),
    new TableCell({width:{size:68,type:WidthType.PERCENTAGE},borders:{top:nb,bottom:sb,left:nb,right:nb},children:[new Paragraph({spacing:{before:60,after:60},children:[new TextRun({text:val||'—',size:18,color:INK,font:'Calibri'})]})]})
  ]});
  const sh=(t)=>new Paragraph({spacing:{before:280,after:60},shading:{fill:V,type:ShadingType.CLEAR},indent:{left:120,right:120},children:[new TextRun({text:t,size:19,bold:true,color:'FFFFFF',font:'Calibri'})]});
  const tb=(rows)=>new Table({width:{size:100,type:WidthType.PERCENTAGE},rows});

  const doc2=new Document({sections:[{
    properties:{page:{margin:{top:720,right:720,bottom:900,left:720}}},
    children:[
      new Paragraph({spacing:{after:0},children:[new TextRun({text:'GREEN STUDIO RD',size:40,bold:true,color:V,font:'Calibri'})]}),
      new Paragraph({spacing:{after:40},children:[new TextRun({text:'Diseño biofílico · Paisajismo sostenible',size:18,color:SO,font:'Calibri'})]}),
      new Paragraph({spacing:{after:20},border:{bottom:{style:BorderStyle.SINGLE,size:6,color:V}},children:[new TextRun({text:'GS-GC-F1  ·  LEVANTAMIENTO COMERCIAL',size:26,bold:true,color:INK,font:'Calibri'})]}),
      new Paragraph({spacing:{before:80,after:300},children:[new TextRun({text:`Fecha: ${d.fecha_levantamiento||'—'}   ·   Encargado: ${d.encargado||'—'}`,size:17,color:SO,font:'Calibri'})]}),
      sh('1.  DATOS DEL CLIENTE'),
      tb([fila('Cliente',d.cliente_nombre),fila('Cédula / RNC',d.cliente_rnc),fila('Teléfono',d.cliente_telefono),fila('WhatsApp',d.cliente_whatsapp),fila('Email',d.cliente_email),fila('¿Cómo nos conoció?',d.como_conocio),fila('Referido',d.referido),fila('Tipo de cliente',d.tipo_cliente)]),
      sh('2.  DATOS DEL PROYECTO'),
      tb([fila('Dirección',d.direccion),fila('Sector / ciudad',d.sector),fila('Nombre del proyecto',d.nombre_proyecto),fila('Líneas de servicio',d.lineas_servicio),fila('Alcance',d.alcance),fila('Área (m²)',d.area_m2),fila('Tipo de espacio',d.tipo_espacio)]),
      sh('3.  REQUERIMIENTOS DEL CLIENTE'),
      tb([fila('Estilo de diseño',d.estilo_diseno),fila('Uso del espacio',d.uso_espacio),fila('Referencias positivas',d.referencias_positivas),fila('No desea',d.referencias_negativas),fila('Componentes de diseño',d.componentes_diseno),fila('Vegetación existente',d.vegetacion_existente),fila('Observaciones',d.observaciones)]),
      sh('4.  CONDICIONES COMERCIALES'),
      tb([fila('Presupuesto estimado',d.presupuesto),fila('Urgencia / plazo',d.urgencia),fila('Condición de pago',d.condicion_pago),fila('Competencia',d.competencia),fila('Fecha visita técnica',d.fecha_visita),fila('Temperatura prospecto',d.temperatura),fila('Notas de ventas',d.notas_ventas)]),
      sh('5.  CIERRE Y ESTADO'),
      tb([fila('Estado del prospecto',d.estado_prospecto),fila('Próxima acción',d.proxima_accion),fila('Fecha de seguimiento',d.fecha_seguimiento),fila('Notificar a Diseño',d.notif_diseno),fila('Confirmación cliente',d.confirmacion_cliente)]),
      new Paragraph({spacing:{before:360},border:{top:{style:BorderStyle.SINGLE,size:2,color:GRD}},alignment:AlignmentType.RIGHT,children:[new TextRun({text:`Registrado por: ${d.encargado}${d.encargado_email?' ('+d.encargado_email+')':''}   ·   ${new Date().toLocaleString('es-DO')}`,size:16,color:'aaaaaa',font:'Calibri'})]}),
      new Paragraph({alignment:AlignmentType.RIGHT,children:[new TextRun({text:'GS-GC-F1 · Versión 1 · 2025 · Uso interno — Green Studio RD',size:16,color:'aaaaaa',font:'Calibri'})]})
    ]
  }]});
  const blob=await Packer.toBlob(doc2);
  const cli=(d.cliente_nombre||'cliente').replace(/[^a-zA-Z0-9\s]/g,'').replace(/\s+/g,'-').slice(0,30);
  const fecha=(d.fecha_levantamiento||new Date().toISOString().split('T')[0]);
  saveAs(blob,`GS-GC-F1_${fecha}_${cli}.docx`);
}

