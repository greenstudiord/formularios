<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>GS-GC-F1 · Levantamiento Comercial</title>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,300;0,500;1,300&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/docx@8/build/index.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/file-saver@2/dist/FileSaver.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@azure/msal-browser@3/dist/msal-browser.min.js"></script>
<style>
  :root {
    --ink:#1c2b1f;--ink-mid:#3d5442;--ink-soft:#6b8870;
    --leaf:#4a7c59;--leaf-pale:#e6f0e9;--leaf-mist:#f2f7f3;
    --gold:#b8933a;--gold-pale:#fdf6e8;--border:#c9d9cc;
    --white:#ffffff;--danger:#c0392b;
  }
  *{box-sizing:border-box;margin:0;padding:0;}
  body{font-family:'DM Sans',sans-serif;background:var(--leaf-mist);color:var(--ink);font-size:14px;line-height:1.6;}
  .page{max-width:880px;margin:0 auto;background:var(--white);}

  /* LOGIN */
  #login-overlay{display:none;min-height:100vh;background:var(--leaf-mist);align-items:center;justify-content:center;padding:24px;}
  #login-overlay.vis{display:flex;}
  .login-card{background:var(--white);border-radius:16px;border:1px solid var(--border);padding:52px 48px;max-width:420px;width:100%;text-align:center;}
  .login-logo{font-family:'Fraunces',serif;font-weight:300;font-size:26px;color:var(--ink);margin-bottom:4px;}
  .login-logo em{font-style:italic;color:var(--leaf);}
  .login-sub{font-size:11px;letter-spacing:1.5px;text-transform:uppercase;color:var(--ink-soft);margin-bottom:36px;font-weight:300;}
  .login-form-name{font-size:13px;color:var(--ink-soft);background:var(--leaf-mist);border:1px solid var(--border);border-radius:8px;padding:10px 16px;margin-bottom:28px;font-weight:500;}
  .btn-ms{width:100%;padding:13px 20px;background:#0078D4;color:white;border:none;border-radius:8px;font-family:'DM Sans',sans-serif;font-size:14px;font-weight:500;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:10px;transition:background .2s;}
  .btn-ms:hover{background:#005fa3;}.btn-ms:disabled{background:#9ab8d4;cursor:not-allowed;}
  .btn-ms svg{width:20px;height:20px;flex-shrink:0;}
  .login-note{margin-top:20px;font-size:11px;color:var(--ink-soft);line-height:1.6;}
  .login-error{margin-top:16px;padding:10px 14px;background:#fdf0ef;border-left:3px solid var(--danger);border-radius:0 6px 6px 0;font-size:12px;color:var(--danger);text-align:left;display:none;}

  /* HEADER */
  .header{background:var(--ink);padding:36px 52px 30px;display:flex;justify-content:space-between;align-items:flex-end;gap:24px;position:relative;overflow:hidden;}
  .header::before{content:'';position:absolute;width:320px;height:320px;border-radius:50%;border:40px solid var(--ink-mid);right:-80px;top:-120px;opacity:.5;}
  .brand{position:relative;z-index:1;}
  .brand h1{font-family:'Fraunces',serif;font-weight:300;font-size:28px;color:var(--white);letter-spacing:-.5px;line-height:1.1;}
  .brand h1 em{font-style:italic;color:#8fc49a;}
  .brand p{font-size:10px;font-weight:300;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,.7);margin-top:5px;}
  .form-meta{position:relative;z-index:1;text-align:right;}
  .form-meta .code{font-family:'Fraunces',serif;font-weight:300;font-size:13px;color:var(--white);letter-spacing:1px;}
  .form-meta .ver{font-size:10px;color:rgba(255,255,255,.6);margin-top:3px;}

  /* USER BAR */
  #user-bar{display:none;background:var(--leaf-pale);border-bottom:1px solid var(--border);padding:10px 52px;justify-content:space-between;align-items:center;}
  #user-bar.vis{display:flex;}
  .user-info{display:flex;align-items:center;gap:10px;}
  .user-avatar{width:32px;height:32px;background:var(--leaf);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:500;color:white;flex-shrink:0;}
  .user-name{font-size:13px;font-weight:500;color:var(--ink);}
  .user-email{font-size:11px;color:var(--ink-soft);}
  .user-badge{font-size:10px;padding:3px 10px;background:var(--leaf);color:white;border-radius:20px;font-weight:500;}

  /* DEMO BADGE */
  #demo-badge{background:#fff8e6;border-bottom:1px solid #f0c040;padding:9px 52px;font-size:11px;color:#7a5e1a;display:flex;align-items:center;gap:8px;}
  #demo-badge.hidden{display:none;}
  .demo-dot{width:8px;height:8px;border-radius:50%;background:#e6a817;flex-shrink:0;}

  /* TOP BAR — solo 2 campos */
  .top-bar{background:var(--leaf-pale);border-bottom:1px solid var(--border);padding:14px 52px;display:grid;grid-template-columns:1fr 1fr;gap:20px;}
  .top-bar .tf label{display:block;font-size:10px;font-weight:500;letter-spacing:1.2px;text-transform:uppercase;color:var(--ink-soft);margin-bottom:4px;}
  .top-bar .tf input{width:100%;border:none;border-bottom:1.5px solid var(--border);background:transparent;font-family:'DM Sans',sans-serif;font-size:13px;color:var(--ink);padding:3px 0;outline:none;}
  .top-bar .tf input:focus{border-bottom-color:var(--leaf);}
  .top-bar .tf input[readonly]{color:var(--ink-soft);cursor:default;}

  /* PROGRESS */
  .progress-bar{display:flex;border-bottom:1px solid var(--border);overflow-x:auto;}
  .step{flex:1;min-width:100px;padding:10px 8px;text-align:center;font-size:10px;font-weight:500;letter-spacing:.8px;text-transform:uppercase;color:var(--ink-soft);border-bottom:2px solid transparent;cursor:pointer;transition:all .2s;white-space:nowrap;}
  .step.active{color:var(--leaf);border-bottom-color:var(--leaf);background:var(--leaf-mist);}
  .step.done{color:var(--ink-soft);border-bottom-color:var(--border);}
  .step.done::before{content:'✓ ';color:var(--leaf);}

  /* BODY */
  .form-body{padding:44px 52px 60px;}
  .section{display:none;animation:fadeIn .25s ease;}
  .section.visible{display:block;}
  @keyframes fadeIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}
  .section-title{font-family:'Fraunces',serif;font-weight:300;font-size:22px;color:var(--ink);margin-bottom:4px;letter-spacing:-.3px;}
  .section-desc{font-size:12px;color:var(--ink-soft);margin-bottom:28px;font-weight:300;}

  .grid-2{display:grid;grid-template-columns:1fr 1fr;gap:20px 32px;}
  .span2{grid-column:span 2;}
  .f{display:flex;flex-direction:column;gap:6px;}
  .f label{font-size:10px;font-weight:500;letter-spacing:1px;text-transform:uppercase;color:var(--ink-soft);}
  .f label .req{color:var(--danger);}
  .f input,.f select,.f textarea{border:1px solid var(--border);border-radius:6px;padding:9px 12px;font-family:'DM Sans',sans-serif;font-size:13px;color:var(--ink);background:var(--white);outline:none;transition:border-color .2s,box-shadow .2s;resize:vertical;}
  .f input:focus,.f select:focus,.f textarea:focus{border-color:var(--leaf);box-shadow:0 0 0 3px rgba(74,124,89,.1);}
  .f input[readonly]{background:var(--leaf-mist);color:var(--ink-soft);cursor:default;}
  .f textarea{min-height:80px;}

  .chips{display:flex;flex-wrap:wrap;gap:8px;margin-top:4px;}
  .chip{padding:7px 14px;border-radius:20px;border:1.5px solid var(--border);font-size:12px;color:var(--ink-soft);cursor:pointer;transition:all .15s;user-select:none;}
  .chip:hover{border-color:var(--leaf);color:var(--leaf);}
  .chip.sel{background:var(--leaf);border-color:var(--leaf);color:var(--white);font-weight:500;}

  .check-cards{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-top:4px;}
  .check-cards.col2{grid-template-columns:repeat(2,1fr);}
  .check-cards.col4{grid-template-columns:repeat(4,1fr);}
  .cc{padding:10px 12px;border:1.5px solid var(--border);border-radius:8px;cursor:pointer;transition:all .15s;user-select:none;display:flex;align-items:center;gap:8px;}
  .cc:hover{border-color:var(--leaf);background:var(--leaf-mist);}
  .cc input{display:none;}
  .cc-box{width:16px;height:16px;border:1.5px solid var(--border);border-radius:3px;flex-shrink:0;display:flex;align-items:center;justify-content:center;transition:all .15s;}
  .cc input:checked~.cc-box{background:var(--leaf);border-color:var(--leaf);}
  .cc input:checked~.cc-box::after{content:'';width:8px;height:5px;border-left:2px solid white;border-bottom:2px solid white;transform:rotate(-45deg) translate(1px,-1px);display:block;}
  .cc input:checked~.cc-text{color:var(--ink);font-weight:500;}
  .cc-text{font-size:12px;color:var(--ink-soft);line-height:1.3;}
  .cc.sel-card{border-color:var(--leaf);background:var(--leaf-pale);}

  .nota{background:var(--gold-pale);border-left:3px solid var(--gold);border-radius:0 6px 6px 0;padding:11px 14px;font-size:12px;color:#7a5e1a;margin-bottom:20px;line-height:1.5;}
  .div{height:1px;background:var(--leaf-pale);margin:28px 0;}

  .budget-opts{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-top:4px;}
  .budget-opt{padding:10px 8px;border:1.5px solid var(--border);border-radius:8px;text-align:center;cursor:pointer;transition:all .15s;user-select:none;}
  .budget-opt:hover{border-color:var(--leaf);}
  .budget-opt.sel{border-color:var(--leaf);background:var(--leaf-pale);}
  .budget-opt .amt{font-size:12px;font-weight:500;color:var(--ink);}
  .budget-opt .lbl{font-size:10px;color:var(--ink-soft);margin-top:2px;}

  .urg-row{display:flex;gap:8px;flex-wrap:wrap;margin-top:4px;}
  .urg-opt{padding:8px 16px;border:1.5px solid var(--border);border-radius:6px;font-size:12px;color:var(--ink-soft);cursor:pointer;transition:all .15s;user-select:none;}
  .urg-opt:hover{border-color:var(--leaf);color:var(--leaf);}
  .urg-opt.sel{background:var(--leaf);border-color:var(--leaf);color:white;font-weight:500;}

  .nav{display:flex;justify-content:space-between;align-items:center;margin-top:40px;padding-top:24px;border-top:1px solid var(--border);}
  .btn{padding:11px 28px;border-radius:6px;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:500;cursor:pointer;border:none;transition:all .2s;}
  .btn-ghost{background:transparent;border:1.5px solid var(--border);color:var(--ink-soft);}
  .btn-ghost:hover{border-color:var(--leaf);color:var(--leaf);}
  .btn-primary{background:var(--ink);color:white;display:flex;align-items:center;gap:8px;}
  .btn-primary:hover{background:var(--ink-mid);}
  .btn-primary.leaf{background:var(--leaf);}
  .btn-primary.leaf:hover{background:#3d6649;}
  .btn-primary:disabled{opacity:.6;cursor:not-allowed;}
  .step-counter{font-size:12px;color:var(--ink-soft);}

  .spinner{display:inline-block;width:14px;height:14px;border:2px solid rgba(255,255,255,.4);border-top-color:white;border-radius:50%;animation:spin .6s linear infinite;flex-shrink:0;}
  @keyframes spin{to{transform:rotate(360deg)}}

  #success{display:none;text-align:center;padding:60px 40px;}
  #success .check-circle{width:64px;height:64px;background:var(--leaf);border-radius:50%;margin:0 auto 24px;display:flex;align-items:center;justify-content:center;}
  #success .check-circle svg{width:32px;height:32px;stroke:white;fill:none;stroke-width:2.5;}
  #success h2{font-family:'Fraunces',serif;font-weight:300;font-size:26px;color:var(--ink);margin-bottom:10px;}
  #success p{font-size:13px;color:var(--ink-soft);max-width:420px;margin:0 auto;line-height:1.7;}
  .next-steps{margin-top:32px;display:flex;gap:12px;justify-content:center;flex-wrap:wrap;}
  .ns-item{padding:12px 20px;border:1px solid var(--border);border-radius:8px;font-size:12px;color:var(--ink-soft);text-align:left;min-width:160px;}
  .ns-item strong{display:block;color:var(--ink);font-size:13px;margin-bottom:3px;}
  .success-actions{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-top:28px;}
  .btn-word{display:inline-flex;align-items:center;gap:8px;padding:12px 28px;background:#2B579A;color:white;border:none;border-radius:8px;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:500;cursor:pointer;transition:background .2s;}
  .btn-word:hover{background:#1e3f70;}
  .btn-word svg{width:18px;height:18px;}
  .btn-pdf{display:inline-flex;align-items:center;gap:8px;padding:12px 28px;background:#c0392b;color:white;border:none;border-radius:8px;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:500;cursor:pointer;transition:background .2s;}
  .btn-pdf:hover{background:#a93226;}
  .btn-pdf svg{width:18px;height:18px;}
  .btn-nuevo{display:inline-flex;align-items:center;gap:8px;padding:12px 28px;background:transparent;color:var(--leaf);border:1.5px solid var(--leaf);border-radius:8px;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:500;cursor:pointer;transition:all .2s;}
  .btn-nuevo:hover{background:var(--leaf-pale);}

  .footer{background:var(--ink);padding:12px 52px;display:flex;justify-content:space-between;}
  .footer span{font-size:10px;color:rgba(255,255,255,.3);letter-spacing:.8px;}

  @media(max-width:620px){
    .header,.top-bar,.form-body,.footer,#user-bar,#demo-badge{padding-left:20px;padding-right:20px;}
    .grid-2{grid-template-columns:1fr;}.span2{grid-column:span 1;}
    .check-cards,.check-cards.col2,.check-cards.col4,.budget-opts{grid-template-columns:1fr 1fr;}
    .header{flex-direction:column;align-items:flex-start;}
    .top-bar{grid-template-columns:1fr;}
    #user-bar{flex-direction:column;align-items:flex-start;gap:8px;}
  }
</style>
</head>
<body>

<!-- LOGIN — solo visible cuando AUTH_ACTIVO = true -->
<div id="login-overlay">
  <div class="login-card">
    <div class="login-logo">Green Studio <em>RD</em></div>
    <div class="login-sub">Diseño biofílico · Paisajismo sostenible</div>
    <div class="login-form-name">GS-GC-F1 · Levantamiento Comercial</div>
    <button class="btn-ms" id="btn-login" onclick="iniciarLogin()">
      <svg viewBox="0 0 21 21" fill="none"><rect x="1" y="1" width="9" height="9" fill="#F25022"/><rect x="11" y="1" width="9" height="9" fill="#7FBA00"/><rect x="1" y="11" width="9" height="9" fill="#00A4EF"/><rect x="11" y="11" width="9" height="9" fill="#FFB900"/></svg>
      Iniciar sesión con Microsoft
    </button>
    <div class="login-error" id="login-error"></div>
    <p class="login-note" id="login-note"></p>
  </div>
</div>

<!-- FORMULARIO -->
<div id="formulario-main" style="display:none">
<div class="page">

  <div class="header">
    <div class="brand"><h1>Green Studio <em>RD</em></h1><p>Diseño biofílico · Paisajismo sostenible</p></div>
    <div class="form-meta"><div class="code">GS-GC-F1 · Levantamiento Comercial</div><div class="ver">Versión 1 · 2025</div></div>
  </div>

  <div id="user-bar">
    <div class="user-info">
      <div class="user-avatar" id="u-avatar">--</div>
      <div><div class="user-name" id="u-name"></div><div class="user-email" id="u-email"></div></div>
    </div>
    <div class="user-badge">Sesión activa · Microsoft 365</div>
  </div>

  <div id="demo-badge">
    <div class="demo-dot"></div>
    <span>Modo local — el formulario funciona completamente. Word y PDF se descargan al guardar. La integración con SharePoint y el canal <strong>A cotizar</strong> en Teams se activa cambiando <strong>AUTH_ACTIVO</strong> a <code>true</code> y configurando los IDs en el bloque CFG.</span>
  </div>

  <!-- TOP BAR — solo fecha y encargado -->
  <div class="top-bar">
    <div class="tf"><label>Fecha de levantamiento</label><input type="date" id="fecha-lev"></div>
    <div class="tf"><label>Encargado de ventas</label><input type="text" id="encargado" placeholder="Nombre completo"></div>
  </div>

  <div class="progress-bar">
    <div class="step active" onclick="goTo(0)">Cliente</div>
    <div class="step" onclick="goTo(1)">Proyecto</div>
    <div class="step" onclick="goTo(2)">Requerimientos</div>
    <div class="step" onclick="goTo(3)">Comercial</div>
    <div class="step" onclick="goTo(4)">Cierre</div>
  </div>

  <div class="form-body">

    <!-- S1 CLIENTE -->
    <div class="section visible" id="s0">
      <div class="section-title">Datos del cliente</div>
      <div class="section-desc">Información del contacto principal y origen del prospecto</div>
      <div class="grid-2" style="margin-bottom:20px;">
        <div class="f"><label>Nombre del cliente <span class="req">*</span></label><input type="text" id="cli-nombre" placeholder="Nombre completo o razón social"></div>
        <div class="f"><label>Cédula / RNC</label><input type="text" id="cli-rnc" placeholder="000-0000000-0"></div>
        <div class="f"><label>Teléfono principal <span class="req">*</span></label><input type="tel" id="cli-tel" placeholder="(809) 000-0000"></div>
        <div class="f"><label>WhatsApp</label><input type="tel" id="cli-wa" placeholder="(809) 000-0000"></div>
        <div class="f span2"><label>Correo electrónico <span class="req">*</span></label><input type="email" id="cli-email" placeholder="cliente@correo.com"></div>
      </div>
      <div class="div"></div>
      <div class="f" style="margin-bottom:20px;">
        <label>¿Cómo nos conoció?</label>
        <div class="chips" id="origen">
          <div class="chip" onclick="selChip(this,'origen')">Instagram</div>
          <div class="chip" onclick="selChip(this,'origen')">Referido</div>
          <div class="chip" onclick="selChip(this,'origen')">Google</div>
          <div class="chip" onclick="selChip(this,'origen')">Facebook</div>
          <div class="chip" onclick="selChip(this,'origen')">Cliente anterior</div>
          <div class="chip" onclick="selChip(this,'origen')">Evento / feria</div>
          <div class="chip" onclick="selChip(this,'origen')">Otro</div>
        </div>
      </div>
      <div class="grid-2">
        <div class="f"><label>Nombre del referido</label><input type="text" id="referido" placeholder="¿Quién los recomendó?"></div>
        <div class="f"><label>Tipo de cliente</label>
          <select id="tipo-cliente"><option value="">Seleccionar…</option><option>Persona física — residencial</option><option>Empresa privada</option><option>Institución / corporativo</option><option>Constructor / desarrollador</option><option>Cliente recurrente</option></select>
        </div>
      </div>
    </div>

    <!-- S2 PROYECTO -->
    <div class="section" id="s1">
      <div class="section-title">Datos del proyecto</div>
      <div class="section-desc">Ubicación, tipo y alcance del trabajo solicitado</div>
      <div class="grid-2" style="margin-bottom:20px;">
        <div class="f span2"><label>Dirección del área a intervenir <span class="req">*</span></label><input type="text" id="direccion" placeholder="Calle, número, sector, ciudad"></div>
        <div class="f"><label>Sector / ciudad</label><input type="text" id="sector" placeholder="Ej. Piantini, Santo Domingo"></div>
        <div class="f"><label>Nombre del proyecto / propiedad</label><input type="text" id="nom-proyecto" placeholder="Ej. Residencia Las Palmas"></div>
      </div>
      <div class="f" style="margin-bottom:20px;">
        <label>Línea de servicio solicitada <span class="req">*</span></label>
        <div class="check-cards" id="lineas-serv">
          <label class="cc"><input type="checkbox" onchange="toggleCC(this)"><span class="cc-box"></span><span class="cc-text">Botánica Permanente</span></label>
          <label class="cc"><input type="checkbox" onchange="toggleCC(this)"><span class="cc-box"></span><span class="cc-text">Botánica Preservada</span></label>
          <label class="cc"><input type="checkbox" onchange="toggleCC(this)"><span class="cc-box"></span><span class="cc-text">Paisajismo</span></label>
          <label class="cc"><input type="checkbox" onchange="toggleCC(this)"><span class="cc-box"></span><span class="cc-text">Mantenimiento</span></label>
          <label class="cc"><input type="checkbox" onchange="toggleCC(this)"><span class="cc-box"></span><span class="cc-text">Natur Grass</span></label>
          <label class="cc"><input type="checkbox" onchange="toggleCC(this)"><span class="cc-box"></span><span class="cc-text">Techos Verdes</span></label>
          <label class="cc"><input type="checkbox" onchange="toggleCC(this)"><span class="cc-box"></span><span class="cc-text">Green Walls</span></label>
        </div>
      </div>
      <div class="f" style="margin-bottom:20px;">
        <label>Alcance del proyecto</label>
        <div class="chips" id="alcance">
          <div class="chip" onclick="selChip(this,'alcance')">Solo diseño</div>
          <div class="chip" onclick="selChip(this,'alcance')">Diseño + ejecución</div>
          <div class="chip" onclick="selChip(this,'alcance')">Solo ejecución</div>
          <div class="chip" onclick="selChip(this,'alcance')">Por definir</div>
        </div>
      </div>
      <div class="grid-2">
        <div class="f"><label>Área aproximada (m²)</label><input type="number" id="area" placeholder="0" step="0.5"></div>
        <div class="f"><label>Tipo de espacio</label>
          <select id="tipo-espacio"><option value="">Seleccionar…</option><option>Exterior — jardín / patio</option><option>Exterior — terraza / azotea</option><option>Interior</option><option>Semi-interior / lobby</option><option>Mixto</option></select>
        </div>
        <div class="f span2"><label>¿Incluye servicios adicionales?</label>
          <div class="check-cards col2">
            <label class="cc"><input type="checkbox" onchange="toggleCC(this)"><span class="cc-box"></span><span class="cc-text">Sistema de riego</span></label>
            <label class="cc"><input type="checkbox" onchange="toggleCC(this)"><span class="cc-box"></span><span class="cc-text">Iluminación</span></label>
